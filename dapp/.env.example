# Copy to .env and fill in real values:
#   cp .env.example .env
#
# Never prefix private keys with EXPO_PUBLIC_.

# ── Hedera operator (dashboard / ops) ───────────────────────────────────────
HEDERA_CLIENT_ID=0.0.XXXXXX
HEDERA_CLIENT_KEY=your_ecdsa_private_key
HEDERA_NETWORK=testnet

# ── Facilitator (signs + submits USDC settlements) ──────────────────────────
FACILITATOR_ACCOUNT_ID=0.0.XXXXXX
FACILITATOR_PRIVATE_KEY=your_ecdsa_private_key

# ── Tokens & payee ──────────────────────────────────────────────────────────
HEDERA_USDC_TOKEN_ID=0.0.429274
HEDERA_PAY_TO_ACCOUNT=0.0.XXXXXX

# ── AI (MiniMax) ────────────────────────────────────────────────────────────
MINIMAX_API_KEY=your_minimax_api_key
# MINIMAX_BASE_URL=https://api.minimax.io/v1

# ── Public client config (safe to expose — addresses only) ──────────────────
EXPO_PUBLIC_API_URL=https://h402.expo.app/api/protected
EXPO_PUBLIC_FACILITATOR_EVM=0xe244adba23d2e84a48176de1eb0740bde27ed850
EXPO_PUBLIC_USDC_EVM=0x0000000000000000000000000000000000068cda

# ── x402 ────────────────────────────────────────────────────────────────────
X402_NETWORK=hedera:testnet

# ── Optional ────────────────────────────────────────────────────────────────
# VERBOSE_DEBUG=true
